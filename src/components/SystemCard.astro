---
interface Props {
  domain: string;
  name: string;
  href?: string;
  comingSoon?: boolean;
  isNew?: boolean;
}

const { domain, name, href, comingSoon = false, isNew = false } = Astro.props;
---

<div class={`relative bg-white rounded-lg border p-4 ${
  comingSoon
    ? 'border-l-4 border-l-slate-300 border-slate-200 border-dashed'
    : isNew
      ? 'border-l-8 border-l-emerald-500 border-slate-200 shadow-[0_0_15px_rgba(16,185,129,0.3)] hover:border-l-emerald-600 hover:shadow-[0_0_20px_rgba(16,185,129,0.4)] transition-all'
      : 'border-l-4 border-l-emerald-500 border-slate-200 hover:border-l-emerald-600 hover:shadow-md transition-all'
}`}>
  {isNew && (
    <div class="absolute bottom-2 right-2">
      <span class="flex items-center justify-center w-12 h-12 text-xs font-bold text-white bg-emerald-600 rounded-full shadow-md animate-pulse">
        ✨<br/>NEW
      </span>
    </div>
  )}
  <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-1">{domain}</p>
  <h3 class="text-base font-semibold text-slate-900 mb-2">{name}</h3>
  {comingSoon ? (
    <span class="text-slate-400 text-sm">Coming soon</span>
  ) : (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center text-emerald-600 font-medium hover:text-emerald-700 transition-colors"
    >
      Try it <span class="ml-1">&rarr;</span>
    </a>
  )}
</div>
